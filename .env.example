# Application
ENV=development
ADDR=:8080
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgres://blueprint:blueprint@localhost:5432/blueprint?sslmode=disable

# Event Log (SQLite)
EVENT_LOG_PATH=./data/events.db

# Auth
JWT_SECRET=change-me-in-production-use-32+-chars
JWT_EXPIRY=24h

# Redis Cache (optional — omit REDIS_ADDR to disable cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=5m

# Worker Pool
WORKER_COUNT=4
WORKER_QUEUE=100

# Outbox Poller
OUTBOX_INTERVAL=5
OUTBOX_BATCH=50

# OpenTelemetry (optional — set OTEL_ENABLED=true to activate)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=go-blueprint
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
METRICS_ADDR=:9091

# gRPC (optional — set GRPC_ENABLED=true to activate alongside the HTTP server)
GRPC_ENABLED=false
GRPC_ADDR=:9090

# MongoDB — Product Catalog (optional — defaults to local MongoDB)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=go_blueprint

# Kafka (optional — set KAFKA_ENABLED=true to activate)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_CUSTOMERS=customers.events
KAFKA_DLQ_TOPIC=customers.events.dlq
KAFKA_CONSUMER_GROUP=go-blueprint
KAFKA_PRODUCER_RETRIES=3
